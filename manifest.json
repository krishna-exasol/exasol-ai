{
  "schemaVersion": 1,
  "bundleVersion": "0.1.0-mvp",
  "dockerOnly": true,
  "nano": {
    "image": "docker.io/exasol/nano:latest",
    "pinBeforeRelease": "Replace with docker.io/exasol/nano@sha256:<digest> or a tested tag."
  },
  "jsonTables": {
    "repository": "https://github.com/exasol-labs/exasol-json-tables.git",
    "ref": "main",
    "pinBeforeRelease": "Replace main with a tested tag or commit."
  },
  "mcpServer": {
    "package": "exasol-mcp-server",
    "version": "1.10.1"
  },
  "images": {
    "registry": "ghcr.io/krishna-exasol",
    "tag": "0.1.0",
    "jsonTables": "exasol-ai-json-tables",
    "mcp": "exasol-ai-mcp"
  },
  "ports": {
    "sql": 8563,
    "web": 8443,
    "mcp": 4896
  }
